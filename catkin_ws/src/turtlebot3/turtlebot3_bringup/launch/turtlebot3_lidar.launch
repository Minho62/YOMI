<launch>
  <arg name="set_frame_id" default="base_scan"/>
  <arg name="lds_model" default="$(env LDS_MODEL)" doc="LDS MODEL [LDS-01, LDS-02, YDLIDAR-G2]"/>

  <group if = "$(eval lds_model == 'LDS-01')">
    <node pkg="hls_lfcd_lds_driver" type="hlds_laser_publisher" name="turtlebot3_lds" output="screen">
      <param name="port" value="/dev/ydlidar"/>
      <param name="frame_id" value="$(arg set_frame_id)"/>
    </node>
  </group>
  <group if = "$(eval lds_model == 'LDS-02')">
    <node pkg="ld08_driver" type="ld08_driver" name="turtlebot3_lds" output="screen" args="LD08">
      <param name="frame_id" value="$(arg set_frame_id)"/>
    </node>
  </group>
  <group if = "$(eval lds_model == 'YDLIDAR-G2')">
    <node pkg="ydlidar_ros_driver" type="ydlidar_ros_driver_node" name="ydlidar_lidar_publisher" output="screen">
      <param name="port" value="/dev/ydlidar"/>
      <param name="frame_id" value="$(arg set_frame_id)"/>
      <param name="baudrate" value="230400"/>
      <param name="lidar_type" value="1"/>
      <param name="device_type" value="0"/>
      <param name="sample_rate" value="5"/>
      <param name="frequency" value="10.0"/>
      <param name="angle_min" value="-180.0"/>
      <param name="angle_max" value="180.0"/>
      <param name="range_min" value="0.1"/>
      <param name="range_max" value="16.0"/>
      <param name="resolution_fixed" value="true"/>
      <param name="auto_reconnect" value="true"/>
      <param name="intensity" value="true"/>
    </node>
  </group>
</launch>
